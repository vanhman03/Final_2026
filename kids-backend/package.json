{
  "name": "brightspark-kids-backend",
  "version": "1.0.0",
  "description": "Backend repository for BrightSpark Kids educational platform using Supabase",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "migrate": "supabase db push",
    "migrate:new": "supabase migration new",
    "db:reset": "supabase db reset",
    "db:seed": "supabase db reset --seed",
    "link": "supabase link --project-ref lhygwavdwdpvqplevepp",
    "status": "supabase status"
  },
  "keywords": [
    "supabase",
    "express",
    "educational-platform",
    "backend",
    "nodejs",
    "typescript"
  ],
  "author": "BrightSpark Kids",
  "license": "UNLICENSED",
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.27",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "supabase": "^1.145.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
